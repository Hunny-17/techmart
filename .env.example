# ===== Application =====
APP_NAME=TechMart
APP_ENV=development
# development | production
# SET TO false IN PRODUCTION. Set true only for local dev.
APP_DEBUG=false
APP_URL=http://localhost/techmart-web
INVOICE_SIGNATURE_KEY=change-this-local-invoice-signature-key

# ===== Database =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=techmart
DB_USER=root
DB_PASS=

# ===== Session =====
SESSION_LIFETIME=1800
# 30 phút tính bằng giây

# ===== Mail =====
# log: ghi email vao storage/mail de demo chac chan
# mail: dung ham mail() cua PHP neu server da cau hinh gui mail
# smtp: gui email that qua SMTP provider nhu Gmail, Brevo, Mailtrap
MAIL_DRIVER=log
MAIL_FROM_EMAIL=no-reply@techmart.test
MAIL_FROM_NAME=TechMart
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TIMEOUT=15

# ===== Manual payment / bank transfer =====
# PAYMENT_BANK_ID dùng mã bank VietQR, ví dụ: VCB, ACB, TCB, MB, BIDV...
PAYMENT_BANK_NAME=MB Bank
PAYMENT_BANK_ID=MB
PAYMENT_BANK_ACCOUNT_NO=100612200517
PAYMENT_BANK_ACCOUNT_NAME=TRAN QUOC HUY
PAYMENT_BANK_BRANCH=
PAYMENT_WALLET_NAME=TechMart Pay
PAYMENT_WALLET_ACCOUNT=TECHMARTPAY
PAYMENT_WALLET_QR_URL=

# ===== Upload =====
UPLOAD_MAX_SIZE=2097152
# 2 MB
